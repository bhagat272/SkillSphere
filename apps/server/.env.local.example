NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# Paste your MongoDB Atlas URL here.
# Example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/skillsphere?retryWrites=true&w=majority
MONGODB_URI=PASTE_YOUR_MONGODB_ATLAS_URL_HERE

# Local auth can run without Redis/email while developing.
REDIS_URL=redis://localhost:6379
DEV_DISABLE_REDIS=true
DEV_AUTO_VERIFY_EMAIL=true
DEV_SKIP_EMAIL_QUEUE=true

JWT_ACCESS_SECRET=skillsphere_dev_access_secret_minimum_32_characters
JWT_REFRESH_SECRET=skillsphere_dev_refresh_secret_minimum_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=dev
SMTP_PASS=dev
EMAIL_FROM=SkillSphere AI <noreply@skillsphere.dev>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id

OPENAI_API_KEY=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
